# Modo manutenção (true = "/" mostra página de manutenção, LP fica em /home)
MAINTENANCE_MODE="true"

# Configurações da Landing Page
PROJECT_NAME="Nome do Cliente ou Projeto"
FIGMA_PAGE_LINK="https://www.figma.com/file/xxxx/nome-do-arquivo"

# Webhook n8n (usado no send-form.php server-side, NÃO expor no frontend)
N8N_WEBHOOK_URL="https://seu-n8n.com/webhook/identificador-unico"

# URL final do site (usada para gerar basePath automaticamente)
# Ex: https://solomocomunicacao.com.br/quinta-dos-bons-ventos (sem barra no final)
# Deixe vazio para servir na raiz do domínio
NEXT_PUBLIC_SITE_URL=""

# Deploy via FTP (cPanel)
FTP_SERVER="ftp.seusite.com.br"
FTP_USER="usuario@seusite.com.br"
FTP_PASSWORD="sua-senha-ftp"
FTP_PATH="/public_html/caminho-da-lp"

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=""

# --- Meta CAPI (Rastreamento Server-Side) ---
# Habilita rastreamento Meta Pixel + CAPI no frontend
NEXT_PUBLIC_ENABLE_TRACKING="false"
# Pixel ID publico (usado no frontend para o pixel browser-side)
NEXT_PUBLIC_META_PIXEL_ID=""
# Pixel ID e Access Token secretos (injetados no messenger.php pelo GitHub Actions)
META_PIXEL_ID=""
META_ACCESS_TOKEN=""
# Codigo de teste para validar eventos no Meta Events Manager (opcional, apenas dev/teste)
NEXT_PUBLIC_META_TEST_EVENT_CODE=""

# Figma API (para MCP tools)
FIGMA_API_KEY="figd_xxxxxxxxxxxxxxxxxxxx"
